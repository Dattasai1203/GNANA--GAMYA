<?xml version="1.0"?>
<!--
  Gnana Gamya — Gazebo Server Configuration
  ══════════════════════════════════════════
  Defines the default system plugins loaded by the Gazebo server
  for every world. These handle physics, user commands (spawn/delete),
  and scene broadcasting to the GUI.

  This file is automatically picked up by Gazebo Sim when placed in
  the worlds/ directory or pointed to via GZ_SIM_SERVER_CONFIG_PATH.

  Note: The Sensors plugin is intentionally omitted here because it
  is declared per-world inside each .world / .sdf file (with the
  ogre2 render engine specified).
-->
<server_config>
  <plugins>

    <!-- Physics simulation (ODE / DART / Bullet via gz-physics) -->
    <plugin
        entity_name="*"
        entity_type="world"
        filename="gz-sim-physics-system"
        name="gz::sim::systems::Physics">
    </plugin>

    <!-- Allows GUI and external tools to spawn, move, delete entities -->
    <plugin
        entity_name="*"
        entity_type="world"
        filename="gz-sim-user-commands-system"
        name="gz::sim::systems::UserCommands">
    </plugin>

    <!-- Broadcasts scene state to the GUI renderer -->
    <plugin
        entity_name="*"
        entity_type="world"
        filename="gz-sim-scene-broadcaster-system"
        name="gz::sim::systems::SceneBroadcaster">
    </plugin>

  </plugins>
</server_config>
